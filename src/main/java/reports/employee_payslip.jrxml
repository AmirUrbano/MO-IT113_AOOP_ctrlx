<?xml version="1.0" encoding="UTF-8"?>
<!-- Created with Jaspersoft Studio version 7.0.6.final using JasperReports Library version 6.19.0  -->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="employee_payslip" pageWidth="595" pageHeight="600" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="c79f5802-f99d-4f29-8036-a323034af186">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="aoop_s2101"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w1" value="14"/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w2" value="980"/>
	<parameter name="EmpIDParameter" class="java.lang.String"/>
	<parameter name="MonthParameter" class="java.lang.Integer"/>
	<parameter name="YearParameter" class="java.lang.Integer"/>
	<parameter name="LogoParameter" class="java.io.InputStream"/>
	<queryString>
		<![CDATA[SELECT
    e.employee_id AS employee_num,
    CONCAT(e.last_name, ', ', e.first_name) AS employee_name,
    e.position,
    e.department,
    e.basic_salary AS monthly_salary,
    e.hourly_rate,
    
    STR_TO_DATE(CONCAT($P{YearParameter}, '-', $P{MonthParameter}, '-01'), '%Y-%m-%d') AS start_date,
    LAST_DAY(STR_TO_DATE(CONCAT($P{YearParameter}, '-', $P{MonthParameter}, '-01'), '%Y-%m-%d')) AS end_date,
    
    COALESCE(att.total_days, 0) AS days_worked,
    COALESCE(att.total_ot_hours, 0) AS overtime_hours,
    ROUND(COALESCE(att.total_ot_hours, 0) * e.hourly_rate * 1.25, 2) AS overtime_pay,
    
    COALESCE(att.total_late_minutes, 0) AS late_minutes,
    ROUND(COALESCE(att.total_late_minutes, 0) * (e.hourly_rate / 60), 2) AS late_deduction,
    
    ROUND(e.basic_salary + (COALESCE(att.total_ot_hours, 0) * e.hourly_rate * 1.25), 2) AS gross_income,

    COALESCE(e.rice_subsidy, 0) AS rice_subsidy,
    COALESCE(e.phone_allowance, 0) AS phone_allowance,
    COALESCE(e.clothing_allowance, 0) AS clothing_allowance,
    ROUND(COALESCE(e.rice_subsidy, 0) + COALESCE(e.phone_allowance, 0) + COALESCE(e.clothing_allowance, 0), 2) AS total_benefits,

    -- SSS, PhilHealth, Pag-IBIG Matrix
    CASE
        WHEN e.basic_salary <= 3250 THEN 135.00 WHEN e.basic_salary <= 3750 THEN 157.50 WHEN e.basic_salary <= 4250 THEN 180.00 WHEN e.basic_salary <= 4750 THEN 202.50 WHEN e.basic_salary <= 5250 THEN 225.00 WHEN e.basic_salary <= 5750 THEN 247.50 WHEN e.basic_salary <= 6250 THEN 270.00 WHEN e.basic_salary <= 6750 THEN 292.50 WHEN e.basic_salary <= 7250 THEN 315.00 WHEN e.basic_salary <= 7750 THEN 337.50 WHEN e.basic_salary <= 8250 THEN 360.00 WHEN e.basic_salary <= 8750 THEN 382.50 WHEN e.basic_salary <= 9250 THEN 405.00 WHEN e.basic_salary <= 9750 THEN 427.50 WHEN e.basic_salary <= 10250 THEN 450.00 WHEN e.basic_salary <= 10750 THEN 472.50 WHEN e.basic_salary <= 11250 THEN 495.00 WHEN e.basic_salary <= 11750 THEN 517.50 WHEN e.basic_salary <= 12250 THEN 540.00 WHEN e.basic_salary <= 12750 THEN 562.50 WHEN e.basic_salary <= 13250 THEN 585.00 WHEN e.basic_salary <= 13750 THEN 607.50 WHEN e.basic_salary <= 14250 THEN 630.00 WHEN e.basic_salary <= 14750 THEN 652.50 WHEN e.basic_salary <= 15250 THEN 675.00 WHEN e.basic_salary <= 15750 THEN 697.50 WHEN e.basic_salary <= 16250 THEN 720.00 WHEN e.basic_salary <= 16750 THEN 742.50 WHEN e.basic_salary <= 17250 THEN 765.00 WHEN e.basic_salary <= 17750 THEN 787.50 WHEN e.basic_salary <= 18250 THEN 810.00 WHEN e.basic_salary <= 18750 THEN 832.50 WHEN e.basic_salary <= 19250 THEN 855.00 WHEN e.basic_salary <= 19750 THEN 877.50 WHEN e.basic_salary <= 20250 THEN 900.00 WHEN e.basic_salary <= 20750 THEN 922.50 WHEN e.basic_salary <= 21250 THEN 945.00 WHEN e.basic_salary <= 21750 THEN 967.50 WHEN e.basic_salary <= 22250 THEN 990.00 WHEN e.basic_salary <= 22750 THEN 1012.50 WHEN e.basic_salary <= 23250 THEN 1035.00 WHEN e.basic_salary <= 23750 THEN 1057.50 WHEN e.basic_salary <= 24250 THEN 1080.00 WHEN e.basic_salary <= 24750 THEN 1102.50 ELSE 1125.00
    END AS social_security_system,

    CASE WHEN (e.basic_salary * 0.03) > 1800 THEN 900.00 ELSE ROUND((e.basic_salary * 0.03) / 2, 2) END AS philhealth,
    CASE WHEN (e.basic_salary * CASE WHEN e.basic_salary <= 1500 THEN 0.01 ELSE 0.02 END) > 100.00 THEN 100.00 ELSE ROUND(e.basic_salary * CASE WHEN e.basic_salary <= 1500 THEN 0.01 ELSE 0.02 END, 2) END AS pag_ibig,

    ROUND(e.basic_salary * 0.12, 2) AS withholding_tax,

    -- TOTAL DEDUCTIONS
    ROUND(
        (CASE WHEN e.basic_salary <= 3250 THEN 135.00 WHEN e.basic_salary <= 3750 THEN 157.50 WHEN e.basic_salary <= 4250 THEN 180.00 WHEN e.basic_salary <= 4750 THEN 202.50 WHEN e.basic_salary <= 5250 THEN 225.00 WHEN e.basic_salary <= 5750 THEN 247.50 WHEN e.basic_salary <= 6250 THEN 270.00 WHEN e.basic_salary <= 6750 THEN 292.50 WHEN e.basic_salary <= 7250 THEN 315.00 WHEN e.basic_salary <= 7750 THEN 337.50 WHEN e.basic_salary <= 8250 THEN 360.00 WHEN e.basic_salary <= 8750 THEN 382.50 WHEN e.basic_salary <= 9250 THEN 405.00 WHEN e.basic_salary <= 9750 THEN 427.50 WHEN e.basic_salary <= 10250 THEN 450.00 WHEN e.basic_salary <= 10750 THEN 472.50 WHEN e.basic_salary <= 11250 THEN 495.00 WHEN e.basic_salary <= 11750 THEN 517.50 WHEN e.basic_salary <= 12250 THEN 540.00 WHEN e.basic_salary <= 12750 THEN 562.50 WHEN e.basic_salary <= 13250 THEN 585.00 WHEN e.basic_salary <= 13750 THEN 607.50 WHEN e.basic_salary <= 14250 THEN 630.00 WHEN e.basic_salary <= 14750 THEN 652.50 WHEN e.basic_salary <= 15250 THEN 675.00 WHEN e.basic_salary <= 15750 THEN 697.50 WHEN e.basic_salary <= 16250 THEN 720.00 WHEN e.basic_salary <= 16750 THEN 742.50 WHEN e.basic_salary <= 17250 THEN 765.00 WHEN e.basic_salary <= 17750 THEN 787.50 WHEN e.basic_salary <= 18250 THEN 810.00 WHEN e.basic_salary <= 18750 THEN 832.50 WHEN e.basic_salary <= 19250 THEN 855.00 WHEN e.basic_salary <= 19750 THEN 877.50 WHEN e.basic_salary <= 20250 THEN 900.00 WHEN e.basic_salary <= 20750 THEN 922.50 WHEN e.basic_salary <= 21250 THEN 945.00 WHEN e.basic_salary <= 21750 THEN 967.50 WHEN e.basic_salary <= 22250 THEN 990.00 WHEN e.basic_salary <= 22750 THEN 1012.50 WHEN e.basic_salary <= 23250 THEN 1035.00 WHEN e.basic_salary <= 23750 THEN 1057.50 WHEN e.basic_salary <= 24250 THEN 1080.00 WHEN e.basic_salary <= 24750 THEN 1102.50 ELSE 1125.00 END) +
        (CASE WHEN (e.basic_salary * 0.03) > 1800 THEN 900.00 ELSE (e.basic_salary * 0.03) / 2 END) +
        (CASE WHEN (e.basic_salary * CASE WHEN e.basic_salary <= 1500 THEN 0.01 ELSE 0.02 END) > 100.00 THEN 100.00 ELSE (e.basic_salary * CASE WHEN e.basic_salary <= 1500 THEN 0.01 ELSE 0.02 END) END) +
        (e.basic_salary * 0.12) +
        (COALESCE(att.total_late_minutes, 0) * (e.hourly_rate / 60)),
        2
    ) AS total_deductions,

    -- TAKE HOME PAY
    ROUND(
        e.basic_salary
        - (CASE WHEN e.basic_salary <= 3250 THEN 135.00 WHEN e.basic_salary <= 3750 THEN 157.50 WHEN e.basic_salary <= 4250 THEN 180.00 WHEN e.basic_salary <= 4750 THEN 202.50 WHEN e.basic_salary <= 5250 THEN 225.00 WHEN e.basic_salary <= 5750 THEN 247.50 WHEN e.basic_salary <= 6250 THEN 270.00 WHEN e.basic_salary <= 6750 THEN 292.50 WHEN e.basic_salary <= 7250 THEN 315.00 WHEN e.basic_salary <= 7750 THEN 337.50 WHEN e.basic_salary <= 8250 THEN 360.00 WHEN e.basic_salary <= 8750 THEN 382.50 WHEN e.basic_salary <= 9250 THEN 405.00 WHEN e.basic_salary <= 9750 THEN 427.50 WHEN e.basic_salary <= 10250 THEN 450.00 WHEN e.basic_salary <= 10750 THEN 472.50 WHEN e.basic_salary <= 11250 THEN 495.00 WHEN e.basic_salary <= 11750 THEN 517.50 WHEN e.basic_salary <= 12250 THEN 540.00 WHEN e.basic_salary <= 12750 THEN 562.50 WHEN e.basic_salary <= 13250 THEN 585.00 WHEN e.basic_salary <= 13750 THEN 607.50 WHEN e.basic_salary <= 14250 THEN 630.00 WHEN e.basic_salary <= 14750 THEN 652.50 WHEN e.basic_salary <= 15250 THEN 675.00 WHEN e.basic_salary <= 15750 THEN 697.50 WHEN e.basic_salary <= 16250 THEN 720.00 WHEN e.basic_salary <= 16750 THEN 742.50 WHEN e.basic_salary <= 17250 THEN 765.00 WHEN e.basic_salary <= 17750 THEN 787.50 WHEN e.basic_salary <= 18250 THEN 810.00 WHEN e.basic_salary <= 18750 THEN 832.50 WHEN e.basic_salary <= 19250 THEN 855.00 WHEN e.basic_salary <= 19750 THEN 877.50 WHEN e.basic_salary <= 20250 THEN 900.00 WHEN e.basic_salary <= 20750 THEN 922.50 WHEN e.basic_salary <= 21250 THEN 945.00 WHEN e.basic_salary <= 21750 THEN 967.50 WHEN e.basic_salary <= 22250 THEN 990.00 WHEN e.basic_salary <= 22750 THEN 1012.50 WHEN e.basic_salary <= 23250 THEN 1035.00 WHEN e.basic_salary <= 23750 THEN 1057.50 WHEN e.basic_salary <= 24250 THEN 1080.00 WHEN e.basic_salary <= 24750 THEN 1102.50 ELSE 1125.00 END)
        - (CASE WHEN (e.basic_salary * 0.03) > 1800 THEN 900.00 ELSE (e.basic_salary * 0.03) / 2 END)
        - (CASE WHEN (e.basic_salary * CASE WHEN e.basic_salary <= 1500 THEN 0.01 ELSE 0.02 END) > 100.00 THEN 100.00 ELSE (e.basic_salary * CASE WHEN e.basic_salary <= 1500 THEN 0.01 ELSE 0.02 END) END)
        - (e.basic_salary * 0.12)
        - (COALESCE(att.total_late_minutes, 0) * (e.hourly_rate / 60))
        + (COALESCE(att.total_ot_hours, 0) * e.hourly_rate * 1.25)
        + COALESCE(e.rice_subsidy, 0) + COALESCE(e.phone_allowance, 0) + COALESCE(e.clothing_allowance, 0),
        2
    ) AS take_home_pay

FROM employees e
LEFT JOIN (
    SELECT
        employee_id,
        COUNT(log_date) AS total_days,
        SUM(CASE WHEN TIME_TO_SEC(TIMEDIFF(time_out, time_in))/3600 > 9 THEN (TIME_TO_SEC(TIMEDIFF(time_out, time_in))/3600) - 9 ELSE 0 END) AS total_ot_hours,
        
        -- grace period 15mins
        SUM(CASE WHEN time_in > '08:15:00' THEN TIME_TO_SEC(TIMEDIFF(time_in, '08:00:00')) / 60 ELSE 0 END) AS total_late_minutes
    FROM attendance_logs
    WHERE MONTH(log_date) = $P{MonthParameter} AND YEAR(log_date) = $P{YearParameter}
    GROUP BY employee_id
) att ON e.employee_id = att.employee_id
WHERE e.employee_id = $P{EmpIDParameter};]]>
	</queryString>
