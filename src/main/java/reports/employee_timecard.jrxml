<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="attendance_report" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="0dabcb50-018d-4443-90fb-46152dab8af1">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="aoop_s2101"/>
	<parameter name="EmpIDParameter" class="java.lang.String"/>
	<parameter name="YearParameter" class="java.lang.Integer"/>
	<parameter name="MonthParameter" class="java.lang.Integer"/>
	<parameter name="LogoParameter" class="java.io.InputStream"/>
	<queryString language="SQL">
		<![CDATA[WITH RECURSIVE DaysOfMonth AS (
    SELECT STR_TO_DATE(CONCAT($P{YearParameter}, '-', $P{MonthParameter}, '-01'), '%Y-%m-%d') AS date_val
    UNION ALL
    SELECT date_val + INTERVAL 1 DAY
    FROM DaysOfMonth
    WHERE date_val < LAST_DAY(STR_TO_DATE(CONCAT($P{YearParameter}, '-', $P{MonthParameter}, '-01'), '%Y-%m-%d'))
)
SELECT 
    e.employee_id, 
    CONCAT(e.first_name, ' ', e.last_name) AS full_name, 
    e.position, 
    jd.department_name AS department, 
    d.date_val AS log_date,
    DATE_FORMAT(d.date_val, '%a') AS day_name,
    a.time_in,

    IF(a.time_in IS NULL, '-', DATE_FORMAT(ADDTIME(a.time_in, '04:00:00'), '%h:%i %p')) AS break_out,

    IF(a.time_in IS NULL, '-', DATE_FORMAT(ADDTIME(a.time_in, '05:00:00'), '%h:%i %p')) AS break_in,
    a.time_out,

    IF(a.time_in IS NOT NULL AND a.time_out IS NOT NULL, 
       ROUND(TIME_TO_SEC(TIMEDIFF(TIMEDIFF(a.time_out, a.time_in), '01:00:00')) / 3600, 2), 
       0) AS hours_worked,
    CASE 
        WHEN DAYNAME(d.date_val) IN ('Saturday', 'Sunday') THEN 'Weekend'
        WHEN h.holiday_name IS NOT NULL THEN CONCAT('Holiday (', h.holiday_name, ')')
        WHEN a.time_in IS NULL THEN '-'
        ELSE 'Present'
    END AS remarks
FROM DaysOfMonth d
CROSS JOIN employees e ON e.employee_id = $P{EmpIDParameter}
INNER JOIN job_departments jd ON e.position = jd.position_name
LEFT JOIN attendance_logs a ON d.date_val = a.log_date AND a.employee_id = e.employee_id
LEFT JOIN holidays h ON d.date_val = h.holiday_date
ORDER BY d.date_val ASC;]]>
	</queryString>
